# Secrets — never commit
.env
.tokens.json

# Databases
*.db
*.sqlite3
*.sqlite3-*
*.db-wal
*.db-shm

# Runtime state (kill switch, halt flags)
# NOTE: must be "state/*" not "state/" — ignoring the DIRECTORY makes the
# .gitkeep negation unreachable (git never descends into ignored dirs).
state/*
!state/.gitkeep

# Logs
logs/*
!logs/.gitkeep

# Python
__pycache__/
*.pyc
venv/
.venv/
.pytest_cache/
*.egg-info/
