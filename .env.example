# MCX Trading Bot — environment template.
# Copy to .env (never commit .env) and fill in what you have.
# PAPER MODE RUNS FINE WITH EVERYTHING LEFT BLANK.

# ---------------------------------------------------------------- mode
# Master switch. Stays false until: paper results validated AND the
# backtest gate passes AND every value in the "money" section below is set.
# The system refuses to start live while any of those are missing.
LIVE_TRADING=false

# Simulated capital used ONLY for paper-mode position sizing (rupees).
# Not real money; has no effect in live mode. Standard MCX lots need
# meaningful margin — for a small-account simulation, prefer
# USE_MINI_CONTRACTS=true over lowering this.
PAPER_CAPITAL=500000

# Trade the MCX mini contracts (CRUDEOILM/NATURALGASM/GOLDM/SILVERM)
# instead of standard lots — for small accounts.
USE_MINI_CONTRACTS=false

# Comma-separated subset to trade (default: all five).
# ACTIVE_SYMBOLS=CRUDEOIL,NATURALGAS,GOLD,SILVER,COPPER

# --------------------------------------------------------------- money
# REQUIRED BEFORE LIVE TRADING — leave unset until then.
# INITIAL_CAPITAL=
# MAX_DAILY_LOSS_PCT=
# MAX_DRAWDOWN_PCT=

# ---------------------------------------------------- Angel One SmartAPI
# From https://smartapi.angelbroking.com (app) + the Angel One mobile app
# (My Profile -> Two Factor Auth -> Show Secret Key for the TOTP secret).
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=
ANGEL_TOTP_KEY=

# SEBI algo tag — required on every live order. Set before live trading.
ALGO_ID_TAG=

# -------------------------------------------------------------- Telegram
# Blank = notifications silently disabled (fine for paper testing).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ------------------------------------------------------ economic calendar
# Finnhub key (https://finnhub.io, free signup; the economic-calendar
# endpoint may need a paid plan). Blank = static weekly fallback (EIA
# Wed/Thu only) — the bot logs which source it used.
FINNHUB_API_KEY=
# Block NEW entries on an instrument this many minutes before one of its
# high-impact events (Fed/CPI/NFP/EIA/OPEC).
EVENT_BLACKOUT_MINUTES=120
